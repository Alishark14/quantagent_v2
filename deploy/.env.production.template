# QuantAgent v2 — Production Environment Variables
# Copy to /opt/quantagent/.env and fill in values.
# This file is a TEMPLATE — never commit with real values.

# ─── LLM Providers ───────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...          # Required. Claude API key.
GROQ_API_KEY=                         # Optional. Text-only cost optimization.

# ─── Exchange Credentials ────────────────────────────────────────────
# Encrypted at rest in DB. Raw only here for the runner process.
HYPERLIQUID_WALLET_ADDRESS=0x...      # Required for trading.
HYPERLIQUID_PRIVATE_KEY=...           # 64 hex chars, no 0x prefix.
HYPERLIQUID_TESTNET=false             # Set true for testnet.

# ─── Database ────────────────────────────────────────────────────────
DATABASE_URL=postgresql://quantagent:PASSWORD@localhost:5432/quantagent
DATABASE_BACKEND=postgresql           # postgresql | sqlite

# ─── Cache ───────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0    # Optional. Falls back to memory cache.
CACHE_BACKEND=memory                  # memory | redis

# ─── API Server ──────────────────────────────────────────────────────
HOST=127.0.0.1                        # Bind to localhost (nginx proxies).
PORT=8000
API_KEYS=your-api-key-1,your-api-key-2  # Comma-separated valid API keys.

# ─── Tracing (LangSmith) ────────────────────────────────────────────
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=lsv2_...
LANGCHAIN_PROJECT=quantagent-v2

# ─── Security ────────────────────────────────────────────────────────
JWT_SECRET=                           # Generate: python -c "import secrets; print(secrets.token_hex(32))"
CREDENTIAL_ENCRYPTION_KEY=            # Generate: python -c "import secrets; print(secrets.token_hex(32))"

# ─── Feature Flags (override config/features.yaml) ──────────────────
FEATURE_SENTINEL_ENABLED=true
FEATURE_REFLECTION_ENABLED=true
FEATURE_ML_REGIME_MODEL=false
FEATURE_PAPER_TRADING_MODE=true       # KEEP TRUE until live-verified.

# ─── Logging ─────────────────────────────────────────────────────────
VERBOSE=                              # Set to "1" for DEBUG level logging.
